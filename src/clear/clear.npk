// clear.npk

func:failsafe = int32(tbb32:err) {
    drop(err);
    exit 1;
};

func:main = int32() {
    // \x1b[H  : Move cursor to home position (0,0)
    // \x1b[2J : Clear entire screen
    // \x1b[3J : Clear scrollback buffer (like modern clear)
    drop(sys(WRITE, 1i64, "\x1b[H\x1b[2J\x1b[3J", 11i64));
    exit 0;
};
