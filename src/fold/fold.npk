// fold.npk

use "../vendor/io_utils.npk".*;
use "../vendor/mem_utils.npk".*;
extern func:npk_mem_read_string = string(int64:ptr, int64:max_len);
extern func:npk_mem_write_byte = void(int64:ptr, int64:offset, int64:val);



use "../vendor/nitpick_args.npk".*;
use "../vendor/sys_constants.npk".*;
use "../vendor/libc_ffi.npk".*;


extern func:npk_mem_read_byte = int64(int64:ptr, int64:offset);


func:print_err = int32(string:s) {
    int64:len = string_length(s);
    drop(sys(SYS_WRITE, 2i64, s, len));
    pass 0i32;
};

func:print_str_safe = int32(string:s) {
    int64:len = string_length(s);
    drop(sys(SYS_WRITE, 1i64, s, len));
    pass 0i32;
};

func:failsafe = int32(tbb32:err) {
    drop(standard_failsafe(err));
    exit 1;
};

func:main = int32(int32:argc, wild int8->:argv) {
    string:args = raw args_load_native(argc, argv);
    int32:arg_count = raw args_count(args);
    
    int64:width = 80i64;
    int32:file_idx = -1i32;
    
    int32:i = 1i32;
    while (i <= arg_count) {
        string:arg = raw args_at(args, i);
        if (string_equals(arg, "-w")) {
            if (i + 1i32 <= arg_count) {
                string:val = raw args_at(args, i + 1i32);
                width = string_to_int(val);
                i = i + 1i32;
            }
        } else {
            if (string_starts_with(arg, "-w")) {
                string:val = string_substring(arg, 2i64, string_length(arg));
                width = string_to_int(val);
            } else {
                file_idx = i;
            }
        }
        i = i + 1i32;
    }
    
    int64:fd = 0i64;
    if (file_idx != -1i32) {
        string:file = raw args_at(args, file_idx);
        fd = sys(SYS_OPEN, file, 0i64, 0i64) ? -1i64;
        if (fd < 0i64) {
            drop(print_err("fold: cannot open '"));
            drop(print_err(file));
            drop(print_err("'\n"));
            exit 1;
        }
        }
    defer { if (fd >= 0i64) { drop(sys(SYS_CLOSE, fd)); } }
    
    int64:buf_size = 65536i64; // 1MB buffer
    wild int8->:buf = alloc(buf_size);
    if (buf < 0i64) { exit 1; }
    
    int64:col = 0i64;
    int32:running = 1i32;
    
    int64:out_buf = malloc(65536i64);
    int64:out_len = 0i64;
    
    while (running == 1i32) {
        int64:n = sys(SYS_READ, fd, buf, buf_size) ? -1i64;
        if (n <= 0i64) {
            running = 0i32;
        } else {
            int64:j = 0i64;
            while (j < n) {
                int64:c = npk_mem_read_byte(buf, j);
                if (c == 10i64) {
                    npk_mem_write_byte(out_buf, out_len, 10i64);
                    out_len = out_len + 1i64;
                    if (out_len >= 65536i64) { drop(sys(SYS_WRITE, 1i64, out_buf, out_len)); out_len = 0i64; }
                    col = 0i64;
                } else {
                    if (col >= width) {
                        npk_mem_write_byte(out_buf, out_len, 10i64);
                        out_len = out_len + 1i64;
                        if (out_len >= 65536i64) { drop(sys(SYS_WRITE, 1i64, out_buf, out_len)); out_len = 0i64; }
                        col = 0i64;
                    }
                    npk_mem_write_byte(out_buf, out_len, c);
                    out_len = out_len + 1i64;
                    if (out_len >= 65536i64) { drop(sys(SYS_WRITE, 1i64, out_buf, out_len)); out_len = 0i64; }
                    col = col + 1i64;
                }
                j = j + 1i64;
            }
        }
    }
    
    if (out_len > 0i64) {
        drop(sys(SYS_WRITE, 1i64, out_buf, out_len));
    }
    drop(nitpick_libc_mem_free(out_buf));
    
    if (fd != 0i64) {
    }
    free(@cast_unchecked<any->>(buf));
    
    exit 0;
};
