// utmp_utils.npk
use "io_utils.npk".*;
use "mem_utils.npk".*;
use "sys_constants.npk".*;
use "libc_ffi.npk".*;
use "../alist.npk".*;

// utmp record size is 384 bytes
// ut_type at offset 0 (short) -> USER_PROCESS is 7
// ut_line at offset 8 (32 bytes)
// ut_user at offset 44 (32 bytes)
// ut_host at offset 76 (256 bytes)

pub func:utmp_read_users = int64() {
    int64:fd = sys(OPEN, "/var/run/utmp", 0i64, 0i64) ? -1i64;
    if (fd < 0i64) { pass 0i64; }
    defer { if (fd >= 0i64) { drop(sys(CLOSE, fd)); } }
    
    int64:lst = raw alist(128i64);
    int64:buf = @cast_unchecked<int64>(alloc(384i64));
    wild int8->:buf_ptr = @cast_unchecked<int8->>(buf);
    defer { dalloc(buf_ptr); }
    
    while (1i32 == 1i32) {
        int64:bytes = sys(READ, fd, buf, 384i64) ? -1i64;
        if (bytes < 384i64) { break; }
        
        int16:ut_type = @cast_unchecked<int16>(@cast_unchecked<int64>(<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(buf)) + (0i64))))); // simplified, usually 2 bytes
        // On linux, ut_type is short. let's just read first byte if little endian
        int64:type_val = @cast_unchecked<int64>(<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(buf)) + (0i64))));
        
        if (type_val == 7i64) { // USER_PROCESS
            // Read ut_user
            int64:user_str = @cast_unchecked<int64>(alloc(33i64));
            defer { if (user_str != 0i64) { drop(dalloc(@cast_unchecked<int8->>(user_str))); } }
            int64:i = 0i64;
            while (i < 32i64) {
                int64:c = @cast_unchecked<int64>(<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(buf)) + (44i64 + i))));
                if (c == 0i64) { break; }
                drop((<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(user_str)) + (i))) = @cast_unchecked<int8>(c)));
                i = i + 1i64;
            }
            drop((<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(user_str)) + (i))) = @cast_unchecked<int8>(0i64)));
            
            // Read ut_line
            int64:line_str = @cast_unchecked<int64>(alloc(33i64));
            defer { if (line_str != 0i64) { drop(dalloc(@cast_unchecked<int8->>(line_str))); } }
            int64:j = 0i64;
            while (j < 32i64) {
                int64:c = @cast_unchecked<int64>(<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(buf)) + (8i64 + j))));
                if (c == 0i64) { break; }
                drop((<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(line_str)) + (j))) = @cast_unchecked<int8>(c)));
                j = j + 1i64;
            }
            drop((<-(@cast_unchecked<int8->>((@cast_unchecked<int64>(line_str)) + (j))) = @cast_unchecked<int8>(0i64)));
            
            // Store as a pair (we can just put them sequentially in alist or return a struct)
            // Nitpick doesn't easily let us return complex objects without structs.
            // Let's store user_str then line_str in the list.
            drop(raw alist_push(lst, user_str));
            drop(raw alist_push(lst, line_str));
        }
    }
    
    pass lst;
};
