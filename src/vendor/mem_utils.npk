// mem_utils.npk

extern "libc" {
}

extern func:npk_mem_read_byte = int64(int64:ptr, int64:offset);
extern func:npk_mem_write_byte = int32(int64:ptr, int64:offset, int64:val);

pub func:ptr_to_string = string(int64:ptr) {
    string:s = "";
    int64:i = 0i64;
    while (npk_mem_read_byte(ptr, i) != 0i64) {
        int64:c = npk_mem_read_byte(ptr, i);
        s = string_concat(s, string_from_char(@cast_unchecked<int8>(c)));
        i = i + 1i64;
    }
    pass s;
};

pub func:str_clone = int64(int64:s) {
    int64:len = 0i64;
    while (npk_mem_read_byte(s, len) != 0i64) {
        len = len + 1i64;
    }
    int64:copy = malloc(len + 1i64);
    int64:i = 0i64;
    while (i < len) {
        drop(npk_mem_write_byte(copy, i, npk_mem_read_byte(s, i)));
        i = i + 1i64;
    }
    drop(npk_mem_write_byte(copy, len, 0i64));
    pass copy;
};
extern func:malloc = int64(int64:bytes);

pub func:nitpick_libc_mem_free = int32(int64:ptr) {
    // GC handles all memory. Stub to satisfy legacy callers.
    pass 0i32;
};
