use "sys_constants.npk".*;
use "libc_ffi.npk".*;
// exec_helper.npk

extern func:npk_mem_read_int64 = int64(int64:ptr, int64:offset);
extern func:npk_mem_write_int64 = int64(int64:ptr, int64:offset, int64:val);
extern func:npk_mem_read_byte = int64(int64:ptr, int64:offset);

pub func:args_load = string() {
    int64:fd = sys(SYS_OPEN, "/proc/self/cmdline", 0i64, 0i64) ? -1i64;
    if (fd < 0i64) { pass("|"); }
    string:result  = "|";
    string:current = "";
    int64:buf = sys!!(SYS_MMAP, 0i64, 65536i64, 3i64, 34i64, -1i64, 0i64) ? 0i64;
    if (buf > 0i64) {
        int64:nread = sys(SYS_READ, fd, buf, 65536i64) ? -1i64;
        if (nread > 0i64) {
            int64:i = 0i64;
            while (i < nread) {
                int64:c = npk_mem_read_byte(buf, i);
                if (c == 0i64) {
                    if (string_length(current) > 0i64) {
                        result = string_concat(result, string_concat(current, "|"));
                        current = "";
                    }
                } else {
                    current = string_concat(current, string_from_char(@cast_unchecked<int8>(c)));
                }
                i = i + 1i64;
            }
        }
        drop(sys!!(SYS_MUNMAP, buf, 65536i64));
    }
    if (string_length(current) > 0i64) {
        result = string_concat(result, string_concat(current, "|"));
    }
    if (fd >= 0i64) { drop(sys(SYS_CLOSE, fd)); }
    pass(result);
};

pub func:sys_execvp_from = int64(int64:start_idx) {
    int64:buf = sys!!(SYS_MMAP, 0i64, 131072i64, 3i64, 34i64, -1i64, 0i64) ? 0i64;
    int64:fd = sys(SYS_OPEN, "/proc/self/cmdline", 0i64, 0i64) ? -1i64; // SYS_OPEN
    defer { if (fd >= 0i64) { drop(sys(SYS_CLOSE, fd)); } }
    int64:bytes = sys(SYS_READ, fd, buf, 131072i64) ? -1i64; // SYS_READ
    
    int64:env_buf = sys!!(SYS_MMAP, 0i64, 131072i64, 3i64, 34i64, -1i64, 0i64) ? 0i64;
    int64:env_fd = sys(SYS_OPEN, "/proc/self/environ", 0i64, 0i64) ? -1i64;
    defer { if (env_fd >= 0i64) { drop(sys(SYS_CLOSE, env_fd)); } }
    int64:env_bytes = sys(SYS_READ, env_fd, env_buf, 131072i64) ? -1i64;
    
    // Count args
    int64:argc_count = 0i64;
    int64:i = 0i64;
    while (i < bytes) {
        int64:c = npk_mem_read_byte(buf, i);
        if (c == 0i64) { argc_count = argc_count + 1i64; }
        i = i + 1i64;
    }
    
    // Count envs
    int64:envc_count = 0i64;
    i = 0i64;
    while (i < env_bytes) {
        int64:c = npk_mem_read_byte(env_buf, i);
        if (c == 0i64) { envc_count = envc_count + 1i64; }
        i = i + 1i64;
    }
    
    int64:argv = sys!!(SYS_MMAP, 0i64, (argc_count + 2i64) * 8i64, 3i64, 34i64, -1i64, 0i64) ? 0i64;
    int64:envp = sys!!(SYS_MMAP, 0i64, (envc_count + 2i64) * 8i64, 3i64, 34i64, -1i64, 0i64) ? 0i64;
    
    int64:arg_idx = 0i64;
    int64:argv_idx = 0i64;
    i = 0i64;
    int64:current_str = buf;
    
    while (i < bytes) {
        int64:c = npk_mem_read_byte(buf, i);
        if (c == 0i64) {
            if (arg_idx >= start_idx) {
                drop(npk_mem_write_int64(argv, argv_idx * 8i64, current_str));
                argv_idx = argv_idx + 1i64;
            }
            arg_idx = arg_idx + 1i64;
            current_str = buf + i + 1i64;
        }
        i = i + 1i64;
    }
    drop(npk_mem_write_int64(argv, argv_idx * 8i64, 0i64)); // NULL terminate
    
    int64:env_idx = 0i64;
    int64:envp_idx = 0i64;
    i = 0i64;
    current_str = env_buf;
    int64:path_ptr = 0i64;
    while (i < env_bytes) {
        int64:c = npk_mem_read_byte(env_buf, i);
        if (c == 0i64) {
            drop(npk_mem_write_int64(envp, envp_idx * 8i64, current_str));
            if (npk_mem_read_byte(current_str, 0i64) == 80i64 && npk_mem_read_byte(current_str, 1i64) == 65i64 && npk_mem_read_byte(current_str, 2i64) == 84i64 && npk_mem_read_byte(current_str, 3i64) == 72i64 && npk_mem_read_byte(current_str, 4i64) == 61i64) {
                path_ptr = current_str + 5i64;
            }
            envp_idx = envp_idx + 1i64;
            current_str = env_buf + i + 1i64;
        }
        i = i + 1i64;
    }
    drop(npk_mem_write_int64(envp, envp_idx * 8i64, 0i64)); // NULL terminate
    
    int64:cmd_ptr = 0i64;
    if (argv_idx > 0i64) {
        cmd_ptr = npk_mem_read_int64(argv, 0i64);
        
        int64:c0 = npk_mem_read_byte(cmd_ptr, 0i64);
        if (c0 == 47i64 || c0 == 46i64 || path_ptr == 0i64) {
            pass sys!!(SYS_EXECVE, cmd_ptr, argv, envp) ? -1i64; // SYS_EXECVE
        }
        
        int64:statbuf = sys!!(SYS_MMAP, 0i64, 4096i64, 3i64, 34i64, -1i64, 0i64) ? 0i64;
        int64:pathbuf = sys!!(SYS_MMAP, 0i64, 4096i64, 3i64, 34i64, -1i64, 0i64) ? 0i64;
        
        int64:cmd_len = 0i64;
        while (npk_mem_read_byte(cmd_ptr, cmd_len) != 0i64) { cmd_len = cmd_len + 1i64; }
        
        int64:p_i = 0i64;
        int32:run = 1i32;
        while (run == 1i32) {
            int64:pc = npk_mem_read_byte(path_ptr, p_i);
            if (pc == 0i64) { run = 0i32; }
            
            int64:j = 0i64;
            int64:tok_i = p_i;
            while (1i32 == 1i32) {
                int64:tc = npk_mem_read_byte(path_ptr, tok_i);
                if (tc == 0i64 || tc == 58i64) { break; } // null or ':'
                if (j >= 4095i64) { break; } // Bounded
                <- (@cast_unchecked<uint8->>(pathbuf + j)) = (@cast_unchecked<uint8>(tc));
                j = j + 1i64;
                tok_i = tok_i + 1i64;
            }
            
            // Add trailing slash if needed
            if (j > 0i64 && j < 4095i64 && npk_mem_read_byte(pathbuf, j - 1i64) != 47i64) {
                <- (@cast_unchecked<uint8->>(pathbuf + j)) = (@cast_unchecked<uint8>(47i64));
                j = j + 1i64;
            }
            
            // Append cmd
            int64:k = 0i64;
            while (k < cmd_len) {
                if (j >= 4095i64) { break; }
                <- (@cast_unchecked<uint8->>(pathbuf + j)) = @cast_unchecked<uint8>(npk_mem_read_byte(cmd_ptr, k));
                j = j + 1i64;
                k = k + 1i64;
            }
            <- (@cast_unchecked<uint8->>(pathbuf + j)) = (@cast_unchecked<uint8>(0i64));
            
            int64:res_stat = sys(SYS_STAT, pathbuf, statbuf) ? -1i64;
            if (res_stat == 0i64) {
                drop(sys!!(SYS_EXECVE, pathbuf, argv, envp));
            }
            
            if (pc == 0i64) { break; }
            p_i = tok_i + 1i64; // skip ':'
        }
        
        pass -1i64;
    }
    
    pass -1i64;
};
