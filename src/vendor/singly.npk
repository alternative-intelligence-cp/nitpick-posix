// singly.npk — Singly-linked list (fast int64 variant)
//
// SList: singly-linked list with O(1) push_front and O(1) push_back
// (tail pointer maintained in header).
//
// Node layout (24 bytes):
//   [0..7]   val  : int64   — element value
//   [8..15]  next : int64   — pointer to next node (0 = null)
//
// Header layout (24 bytes, malloc'd):
//   [0..7]   head : int64   — pointer to first node (0 = empty)
//   [8..15]  tail : int64   — pointer to last node  (0 = empty)
//   [16..23] size : int64   — number of elements
//
// API (via pub Type:SList):
//   create()                → int64 handle
//   destroy(sl)             → int32
//   push_front(sl, val)     → int32  O(1)
//   push_back(sl, val)      → int32  O(1)
//   pop_front(sl)           → int64  O(1), -1 if empty
//   peek_front(sl)          → int64  O(1), -1 if empty
//   peek_back(sl)           → int64  O(1), -1 if empty
//   contains(sl, val)       → int32  O(n) — 1 if found
//   remove_first(sl, val)   → int32  O(n) — removes first occurrence
//   len(sl)                 → int64
//   is_empty(sl)            → int32
//   clear(sl)               → int32  (frees all nodes, keeps header)
//   reverse(sl)             → int32  O(n) in-place reversal

extern "libc" {
    func:nitpick_libc_mem_malloc    = int64(int64:bytes);
    func:nitpick_libc_mem_free      = int32(int64:ptr);
    func:nitpick_libc_mem_zero      = int32(int64:ptr, int64:bytes);
    func:nitpick_libc_mem_read_i64  = int64(int64:ptr, int64:offset);
    func:nitpick_libc_mem_write_i64 = void(int64:ptr, int64:offset, int64:val);
}

// ── Node helpers ─────────────────────────────────────────────────────────────

func:sl_node_val  = int64(int64:n) { pass nitpick_libc_mem_read_i64(n, 0i64);  };
func:sl_node_next = int64(int64:n) { pass nitpick_libc_mem_read_i64(n, 8i64);  };

func:sl_node_set_val  = void(int64:n, int64:v) { nitpick_libc_mem_write_i64(n,  0i64, v); };
func:sl_node_set_next = void(int64:n, int64:v) { nitpick_libc_mem_write_i64(n,  8i64, v); };

func:sl_alloc_node = int64(int64:val) {
    int64:n = nitpick_libc_mem_malloc(16i64);
    int32:z = nitpick_libc_mem_zero(n, 16i64);
    sl_node_set_val(n, val);
    pass n;
};

// ── Header helpers ───────────────────────────────────────────────────────────

func:sl_head = int64(int64:sl) { pass nitpick_libc_mem_read_i64(sl,  0i64); };
func:sl_tail = int64(int64:sl) { pass nitpick_libc_mem_read_i64(sl,  8i64); };
func:sl_size = int64(int64:sl) { pass nitpick_libc_mem_read_i64(sl, 16i64); };

func:sl_set_head = void(int64:sl, int64:v) { nitpick_libc_mem_write_i64(sl,  0i64, v); };
func:sl_set_tail = void(int64:sl, int64:v) { nitpick_libc_mem_write_i64(sl,  8i64, v); };
func:sl_set_size = void(int64:sl, int64:v) { nitpick_libc_mem_write_i64(sl, 16i64, v); };

// ── Core functions ───────────────────────────────────────────────────────────

func:slist_create = int64() {
    int64:sl = nitpick_libc_mem_malloc(24i64);
    int32:z  = nitpick_libc_mem_zero(sl, 24i64);
    pass sl;
};

func:slist_push_front = int32(int64:sl, int64:val) {
    int64:n    = raw sl_alloc_node(val);
    int64:head = raw sl_head(sl);
    sl_node_set_next(n, head);
    sl_set_head(sl, n);
    if (head == 0i64) { sl_set_tail(sl, n); }
    sl_set_size(sl, raw sl_size(sl) + 1i64);
    pass 0i32;
};

func:slist_push_back = int32(int64:sl, int64:val) {
    int64:n    = raw sl_alloc_node(val);
    int64:tail = raw sl_tail(sl);
    if (tail == 0i64) {
        sl_set_head(sl, n);
    } else {
        sl_node_set_next(tail, n);
    }
    sl_set_tail(sl, n);
    sl_set_size(sl, raw sl_size(sl) + 1i64);
    pass 0i32;
};

func:slist_pop_front = int64(int64:sl) {
    int64:head = raw sl_head(sl);
    if (head == 0i64) { pass -1i64; }
    int64:val  = raw sl_node_val(head);
    int64:next = raw sl_node_next(head);
    sl_set_head(sl, next);
    if (next == 0i64) { sl_set_tail(sl, 0i64); }
    sl_set_size(sl, raw sl_size(sl) - 1i64);
    int32:f = nitpick_libc_mem_free(head);
    pass val;
};

func:slist_peek_front = int64(int64:sl) {
    int64:head = raw sl_head(sl);
    if (head == 0i64) { pass -1i64; }
    pass raw sl_node_val(head);
};

func:slist_peek_back = int64(int64:sl) {
    int64:tail = raw sl_tail(sl);
    if (tail == 0i64) { pass -1i64; }
    pass raw sl_node_val(tail);
};

func:slist_contains = int32(int64:sl, int64:val) {
    int64:cur = raw sl_head(sl);
    loop(0i64, raw sl_size(sl), 1i64) {
        if (cur == 0i64) { pass 0i32; }
        int64:v = raw sl_node_val(cur);
        if (v == val) { pass 1i32; }
        cur = raw sl_node_next(cur);
    }
    pass 0i32;
};

func:slist_remove_first = int32(int64:sl, int64:val) {
    int64:cur  = raw sl_head(sl);
    int64:prev = 0i64;
    int64:sz   = raw sl_size(sl);
    loop(0i64, sz, 1i64) {
        if (cur == 0i64) { pass -1i32; }
        int64:v = raw sl_node_val(cur);
        if (v == val) {
            int64:next = raw sl_node_next(cur);
            if (prev == 0i64) {
                sl_set_head(sl, next);
            } else {
                sl_node_set_next(prev, next);
            }
            if (next == 0i64) { sl_set_tail(sl, prev); }
            sl_set_size(sl, sz - 1i64);
            int32:f = nitpick_libc_mem_free(cur);
            pass 0i32;
        }
        prev = cur;
        cur  = raw sl_node_next(cur);
    }
    pass -1i32;
};

func:slist_clear = int32(int64:sl) {
    int64:cur = raw sl_head(sl);
    loop(0i64, raw sl_size(sl), 1i64) {
        if (cur == 0i64) { pass 0i32; }
        int64:next = raw sl_node_next(cur);
        int32:f    = nitpick_libc_mem_free(cur);
        cur = next;
    }
    sl_set_head(sl, 0i64);
    sl_set_tail(sl, 0i64);
    sl_set_size(sl, 0i64);
    pass 0i32;
};

func:slist_destroy = int32(int64:sl) {
    int32:c = raw slist_clear(sl);
    pass nitpick_libc_mem_free(sl);
};

func:slist_reverse = int32(int64:sl) {
    int64:prev = 0i64;
    int64:cur  = raw sl_head(sl);
    int64:tail = raw sl_tail(sl);
    int64:sz   = raw sl_size(sl);
    loop(0i64, sz, 1i64) {
        if (cur == 0i64) { pass 0i32; }
        int64:next = raw sl_node_next(cur);
        sl_node_set_next(cur, prev);
        prev = cur;
        cur  = next;
    }
    // swap head / tail
    int64:old_head = raw sl_head(sl);
    sl_set_head(sl, tail);
    sl_set_tail(sl, old_head);
    pass 0i32;
};

// ── Type wrapper ─────────────────────────────────────────────────────────────

pub Type:SList = {
    func:create        = int64()                    { pass raw slist_create();             };
    func:destroy       = int32(int64:sl)            { pass raw slist_destroy(sl);          };
    func:push_front    = int32(int64:sl, int64:val) { pass raw slist_push_front(sl, val);  };
    func:push_back     = int32(int64:sl, int64:val) { pass raw slist_push_back(sl, val);   };
    func:pop_front     = int64(int64:sl)            { pass raw slist_pop_front(sl);        };
    func:peek_front    = int64(int64:sl)            { pass raw slist_peek_front(sl);       };
    func:peek_back     = int64(int64:sl)            { pass raw slist_peek_back(sl);        };
    func:contains      = int32(int64:sl, int64:val) { pass raw slist_contains(sl, val);    };
    func:remove_first  = int32(int64:sl, int64:val) { pass raw slist_remove_first(sl,val); };
    func:len           = int64(int64:sl)            { pass raw sl_size(sl);                };
    func:is_empty      = int32(int64:sl)            { int64:s = raw sl_size(sl); if (s == 0i64) { pass 1i32; } pass 0i32; };
    func:clear         = int32(int64:sl)            { pass raw slist_clear(sl);            };
    func:reverse       = int32(int64:sl)            { pass raw slist_reverse(sl);          };
};
